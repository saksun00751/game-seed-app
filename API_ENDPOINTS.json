{
  "deposit_qr_flow": {
    "step_1": {
      "name": "สร้างรายการฝากเงิน",
      "endpoint": {
        "method": "POST",
        "path": "/api/{bankId}/deposit/create"
      },
      "request_body": {
        "amount": 100.00
      },
      "path_parameters": {
        "bankId": "smkpay"
      },
      "response_success": {
        "success": true,
        "data": {
          "request_id": "REQ20260428123456",
          "txid": "TXN987654321001",
          "status": "pending",
          "amount": 100.00,
          "payamount": 100.00
        }
      },
      "response_error": {
        "success": false,
        "message": "ข้อมูลไม่ถูกต้อง",
        "status": 400
      }
    },
    "step_2": {
      "name": "ดึง QR Code",
      "endpoint": {
        "method": "GET",
        "path": "/api/{bankId}/qrcode/{requestId}"
      },
      "path_parameters": {
        "bankId": "smkpay",
        "requestId": "REQ20260428123456"
      },
      "response_success": {
        "success": true,
        "data": {
          "request_id": "REQ20260428123456",
          "txid": "TXN987654321001",
          "status": "pending",
          "amount": 100.00,
          "payamount": 100.00,
          "qrcode": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAACg...",
          "qr_string": "00020101021229370016A000000677010112662200213330...",
          "expired_date": "2026-04-28 14:35:45",
          "member": {
            "user_name": "user123",
            "name": "นางสาว สมหญิง"
          }
        }
      },
      "response_error": {
        "success": false,
        "message": "ไม่สามารถโหลด QR Code ได้",
        "status": 500
      }
    },
    "step_3": {
      "name": "Check Payment Status",
      "endpoint": {
        "method": "GET",
        "path": "/api/{bankId}/deposit/status/{txid}"
      },
      "path_parameters": {
        "bankId": "smkpay",
        "txid": "TXN987654321001"
      },
      "response_pending": {
        "success": true,
        "data": {
          "txid": "TXN987654321001",
          "status": "pending",
          "amount": 100.00,
          "payment_status": "waiting_payment"
        }
      },
      "response_paid": {
        "success": true,
        "data": {
          "txid": "TXN987654321001",
          "status": "success",
          "amount": 100.00,
          "payment_status": "paid",
          "paid_date": "2026-04-28 14:28:30"
        }
      },
      "response_expired": {
        "success": true,
        "data": {
          "txid": "TXN987654321001",
          "status": "expired",
          "amount": 100.00,
          "payment_status": "expired"
        }
      }
    },
    "step_4": {
      "name": "Mark QR as Expired",
      "endpoint": {
        "method": "POST",
        "path": "/api/{bankId}/deposit/expire/{txid}"
      },
      "path_parameters": {
        "bankId": "smkpay",
        "txid": "TXN987654321001"
      },
      "response_success": {
        "success": true,
        "message": "QR Code marked as expired"
      }
    }
  }
}
